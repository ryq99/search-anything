# ── Backend ────────────────────────────────────────────────
CLOUD_BACKEND=local          # "local" | "aws"

# ── Local backend ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
HF_TOKEN=hf_...
# SYNTHESIS_MODEL=claude-haiku-4-5-20251001   # optional override

# ── Parsing ────────────────────────────────────────────────
# LOCAL_PARSER=docling          # "docling" | "liteparse"  (A/B parse quality)
# PARSER_ENABLE_OCR=true        # OCR scanned/mixed pages

# ── Chunking ───────────────────────────────────────────────
# LOCAL_CHUNKER=docling             # "docling" | (future strategies)
# CHUNK_TOKENIZER=Snowflake/snowflake-arctic-embed-l-v2.0  # defaults to EMBED_MODEL_ID
# CHUNK_MAX_TOKENS=1024             # hard ceiling per chunk (token-aware split)
# CHUNK_MERGE_PEERS=true            # merge undersized same-heading neighbours
# CHUNK_MERGE_LIST_ITEMS=true       # collapse consecutive list items into one chunk

# ── AWS backend ────────────────────────────────────────────
# AWS_PROFILE=default
# AWS_REGION=us-east-1
# S3_BUCKET=my-rag-books
# DYNAMODB_TABLE=rag-processed-books
# AURORA_CONN_STRING=postgresql://user:pass@cluster.us-east-1.rds.amazonaws.com:5432/ragdb
# BEDROCK_REGION=us-east-1
