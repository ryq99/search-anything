CLOUD_BACKEND=local   # local | aws

# ── Ingestion pipeline ────────────────────────────────────────────────────────

# LOCAL_PARSER=docling          # docling | liteparse
# PARSER_ENABLE_OCR=true

# LOCAL_CHUNKER=docling         # docling | liteparse
# CHUNK_TOKENIZER=Snowflake/snowflake-arctic-embed-l-v2.0
# CHUNK_MAX_TOKENS=1024
# CHUNK_MERGE_PEERS=true
# CHUNK_MERGE_LIST_ITEMS=true

LOCAL_LLM_BASE_URL=http://localhost:11434
# LOCAL_SUMMARY_MODEL=gemma4:e4b
# CLOUD_SUMMARY_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0   # Bedrock cross-region id

# MILVUS_INDEX_TYPE=FLAT
# MILVUS_METRIC_TYPE=COSINE
# MILVUS_HNSW_M=16
# MILVUS_HNSW_EF_CONSTRUCTION=200
# MILVUS_IVF_NLIST=128

# ── Query pipeline ────────────────────────────────────────────────────────────

# RETRIEVAL_K=10
# RETRIEVAL_EXPR=headings != 'Contents'     # local (Milvus) only
# RETRIEVAL_EXCLUDE_HEADINGS=Contents        # AWS (KB) equivalent — comma-separated

# LOCAL_SYNTHESIS_MODEL=gemma4:e4b
# CLOUD_SYNTHESIS_MODEL=us.anthropic.claude-sonnet-4-6

# ── Infrastructure ────────────────────────────────────────────────────────────

# Secrets: set here for local dev, OR leave unset and they're fetched from AWS SSM
# Parameter Store (HF_TOKEN->hf_hub_access_token, ANTHROPIC_API_KEY->anthropic_api_key).
# HF_TOKEN=            # HF tokenizer/model download (local backend)
# ANTHROPIC_API_KEY=   # optional/legacy — not used by AWS (IAM) or local (Ollama)

# --- AWS backend (CLOUD_BACKEND=aws) ---
# AWS_PROFILE=default
# AWS_REGION=us-west-2
# S3_BUCKET=my-rag-bucket
# DYNAMODB_TABLE=my-rag-table       # composite key: PK content_hash (S), SK pipeline_config_hash (S)
# BEDROCK_REGION=us-west-2
# BEDROCK_KNOWLEDGE_BASE_ID=        # from the Bedrock KB (VECTOR type, S3 Vectors store)
# BEDROCK_DATA_SOURCE_ID=           # S3 data source with chunkingStrategy=NONE, prefix chunks/
# BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
# KB_SYNC_POLL_INTERVAL=5           # seconds between KB ingestion-job status checks
# KB_SYNC_TIMEOUT=600               # max seconds to wait for a KB sync
# SUMMARY_BATCH_MODE=false          # route summarization through Bedrock Batch Inference (~50% cheaper, async)
# BEDROCK_BATCH_ROLE_ARN=           # service role Bedrock assumes for batch S3 I/O
# BEDROCK_BATCH_S3_PREFIX=batch/    # S3 prefix (under S3_BUCKET) for batch input/output
